#!/bin/sh
# repo-governance-hub global pre-commit
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$HOOK_DIR/.." && pwd)"

if [ -f "$ROOT/scripts/verify-kit.ps1" ]; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/verify-kit.ps1"
  status=$?
  if [ $status -ne 0 ]; then
    echo "[BLOCK] repo-governance-hub integrity check failed"
    exit $status
  fi
fi

if [ -f "$ROOT/scripts/governance/fast-check.ps1" ]; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/governance/fast-check.ps1" -DisableAutoEscalation
  status=$?
  if [ $status -ne 0 ]; then
    echo "[BLOCK] governance fast-check failed"
    exit $status
  fi
fi
exit 0

