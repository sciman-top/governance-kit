#!/bin/sh
# governance-kit global pre-push
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
KIT_ROOT="$(cd "$HOOK_DIR/.." && pwd)"

if [ -f "$KIT_ROOT/scripts/verify.ps1" ]; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$KIT_ROOT/scripts/verify.ps1"
  status=$?
  if [ $status -ne 0 ]; then
    echo "[BLOCK] governance target verification failed"
    exit $status
  fi
fi
exit 0
