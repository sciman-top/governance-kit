{
  "schema_version": "1.0",
  "mode": "observe",
  "enabled_by_default": false,
  "default_files": [
    ".codex/config.toml",
    ".codex/agents/planner.toml",
    ".codex/agents/reuse-analyst.toml",
    ".codex/agents/reviewer.toml"
  ],
  "repos": [
    {
      "repoName": "repo-governance-hub",
      "enabled": true
    },
    {
      "repoName": "skills-manager",
      "enabled": true
    },
    {
      "repoName": "ClassroomToolkit",
      "enabled": true
    }
  ],
  "prompt_registry": {
    "required_fields": [
      "prompt_id",
      "owner",
      "task_class",
      "eval_set",
      "rollback_ref",
      "cacheability",
      "last_eval_at",
      "promotion_mode"
    ],
    "entries": [
      {
        "prompt_id": "runtime.observe.default.v1",
        "owner": "repo-governance-hub",
        "task_class": "governance_runtime",
        "eval_set": "agent-runtime-smoke",
        "rollback_ref": "git restore config/agent-runtime-policy.json",
        "cacheability": "cacheable",
        "last_eval_at": "2026-04-15",
        "promotion_mode": "observe"
      }
    ]
  },
  "tool_contracts": {
    "required_fields": [
      "tool_name",
      "risk_class",
      "approval_policy",
      "timeout_ms",
      "retry_policy",
      "trace_attrs",
      "sandbox_boundary",
      "side_effect_class"
    ],
    "entries": [
      {
        "tool_name": "powershell",
        "risk_class": "medium",
        "approval_policy": "auto_if_reversible",
        "timeout_ms": 300000,
        "retry_policy": "retry_once_on_timeout",
        "trace_attrs": [
          "tool_name",
          "exit_code",
          "duration_ms"
        ],
        "sandbox_boundary": "repo_workspace",
        "side_effect_class": "filesystem_and_process"
      }
    ]
  },
  "context_management": {
    "compaction": {
      "enabled": true,
      "strategy": "advisory"
    },
    "cacheability_markers_enabled": true
  },
  "memory_policy": {
    "session_memory": {
      "enabled": true
    },
    "durable_memory": {
      "enabled": false
    },
    "forbidden_memory_classes": [
      "secrets",
      "raw_credentials"
    ],
    "retention_rules": {
      "session_memory_days": 7,
      "durable_memory_days": 30
    },
    "audit_requirements": {
      "record_memory_write_reason": true,
      "record_source_refs": true,
      "record_purge_action": true
    },
    "purge_on_user_delete": true
  },
  "agent_evals": {
    "required_suites": [
      "smoke",
      "regression",
      "adversarial",
      "cost"
    ],
    "minimum_eval_freshness_days": 14,
    "promotion_blocks_on_missing_eval": true,
    "trace_grading_enabled": true
  },
  "agent_observability": {
    "required_metrics": [
      "agent_task_success_rate",
      "runtime_eval_pass_rate",
      "cache_hit_rate",
      "cost_per_successful_run",
      "tool_error_rate",
      "compaction_count"
    ],
    "trajectory_fields": [
      "run_id",
      "issue_id",
      "problem_statement_ref",
      "trajectory_ref",
      "checkpoint_ref",
      "replay_ref",
      "rollback_ref",
      "human_interrupt_count"
    ]
  },
  "cost_controls": {
    "track_token_cost": true
  },
  "observe_to_enforce": {
    "enabled": true,
    "minimum_observe_days": 14
  }
}
