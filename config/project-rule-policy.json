{
  "allowProjectRulesForRepos": [
    "E:/CODE/ClassroomToolkit",
    "E:/CODE/skills-manager",
    "E:/CODE/governance-kit"
  ],
  "defaults": {
    "allow_auto_fix": true,
    "allow_rule_optimization": true,
    "allow_local_optimize_without_backflow": false,
    "max_autonomous_iterations": 6,
    "max_repeated_failure_per_step": 2,
    "enable_no_progress_guard": true,
    "max_no_progress_iterations": 2,
    "token_budget_mode": "lite",
    "stop_on_irreversible_risk": true,
    "forbid_breaking_contract": true,
    "clarification_mode_default": "direct_fix",
    "clarification_scenario_default": "bugfix",
    "clarification_trigger_attempt_threshold": 2,
    "clarification_max_questions": 3,
    "auto_commit_enabled": false,
    "auto_commit_on_checkpoints": [],
    "auto_commit_message_prefix": "\u6cbb\u7406\u91cc\u7a0b\u7891\u81ea\u52a8\u63d0\u4ea4"
  },
  "repos": [
    {
      "repoName": "ClassroomToolkit",
      "auto_commit_enabled": true,
      "auto_commit_on_checkpoints": [
        "after_backflow",
        "after_redistribute_verify",
        "cycle_complete"
      ],
      "auto_commit_message_prefix": "\u6cbb\u7406\u91cc\u7a0b\u7891\u81ea\u52a8\u63d0\u4ea4"
    },
    {
      "repoName": "skills-manager",
      "auto_commit_enabled": true,
      "auto_commit_on_checkpoints": [
        "after_backflow",
        "after_redistribute_verify",
        "cycle_complete"
      ],
      "auto_commit_message_prefix": "\u6cbb\u7406\u91cc\u7a0b\u7891\u81ea\u52a8\u63d0\u4ea4"
    },
    {
      "repoName": "governance-kit",
      "token_budget_mode": "deep",
      "auto_commit_enabled": true,
      "auto_commit_on_checkpoints": [
        "after_backflow",
        "after_redistribute_verify",
        "cycle_complete"
      ],
      "auto_commit_message_prefix": "\u6cbb\u7406\u91cc\u7a0b\u7891\u81ea\u52a8\u63d0\u4ea4"
    }
  ]
}
