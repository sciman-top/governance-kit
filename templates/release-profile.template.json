{
  "schema_version": "1.0",
  "project_type": "dotnet",
  "release_enabled": true,
  "owner": "team-or-owner",
  "clarification_policy_ref": "config/clarification-policy.json",
  "clarification_mode_default": "direct_fix",
  "clarification_scenario_default": "bugfix",
  "classification": {
    "release_decision": "enabled-by-signals",
    "detected_release_signals": [
      "scripts/release/preflight-check.ps1",
      "scripts/release/prepare-distribution.ps1",
      ".github/workflows/release-package.yml"
    ]
  },
  "policies": {
    "signing": {
      "required": false,
      "mode": "none-personal",
      "allow_paid_signing": false
    },
    "compatibility": {
      "matrix_required": true,
      "minimum_os": [
        "Windows 10 22H2",
        "Windows 11 22H2"
      ],
      "architectures": [
        "x64"
      ]
    },
    "packaging": {
      "default_channel": "standard",
      "channels": [
        "standard",
        "offline"
      ],
      "distribution_forms": [
        "installer",
        "portable"
      ],
      "network_modes": [
        "online",
        "offline"
      ],
      "require_framework_dependent": true,
      "require_self_contained": true
    },
    "anti_false_positive": {
      "prefer_zip": true,
      "disallow_self_extracting_archive": true,
      "disallow_obfuscation": true,
      "disallow_runtime_downloader": true
    },
    "traceability": {
      "require_sha256": true,
      "require_release_manifest": true,
      "require_changelog": true
    }
  },
  "gates": {
    "build": "dotnet build <solution-or-project> -c Debug",
    "test": "dotnet test <test-project> -c Debug",
    "contract_invariant": "dotnet test <test-project> -c Debug --filter \"FullyQualifiedName~Contract|FullyQualifiedName~Invariant\"",
    "hotspot": "powershell -File scripts/quality/check-hotspot-line-budgets.ps1"
  },
  "release": {
    "preflight": "powershell -File scripts/release/preflight-check.ps1 -SkipTests",
    "prepare": "powershell -File scripts/release/prepare-distribution.ps1 -Version <version> -PackageMode both",
    "workflow_files": [
      ".github/workflows/release-package.yml"
    ],
    "output_root": "artifacts/release",
    "manifest": "artifacts/release/<version>/release-manifest.json"
  }
}
