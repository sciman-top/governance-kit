#!/bin/sh
# repo-governance-hub pre-push hook
ROOT="$(git config --get governance.root)"
if [ -z "$ROOT" ]; then
  ROOT="${GOVERNANCE_ROOT}"
fi

if [ -z "$ROOT" ]; then
  echo "[WARN] governance.root is not configured; skip governance verify"
  exit 0
fi

powershell -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/verify.ps1" -TrackedFilesScope outgoing
status=$?
if [ $status -ne 0 ]; then
  echo "[BLOCK] governance verify failed"
  exit $status
fi
exit 0

