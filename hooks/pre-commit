#!/bin/sh
# repo-governance-hub pre-commit hook
KIT_ROOT="$(git config --get governance.kitRoot)"
if [ -z "$KIT_ROOT" ]; then
  KIT_ROOT="${GOVERNANCE_KIT_ROOT}"
fi

if [ -z "$KIT_ROOT" ]; then
  echo "[WARN] governance.kitRoot is not configured; skip governance verify"
  exit 0
fi

powershell -NoProfile -ExecutionPolicy Bypass -File "$KIT_ROOT/scripts/verify.ps1" -TrackedFilesScope staged
status=$?
if [ $status -ne 0 ]; then
  echo "[BLOCK] governance verify failed"
  exit $status
fi
exit 0

